  "keyFeatures": [
    "4-level cybersecurity education game with progressive difficulty",
    "Real reverse shell demonstration using TCP socket communication on port 5050",
    "Cross-platform persistence simulation (Windows Registry, Linux Crontab, macOS LaunchAgent)",
    "Dependency auto-installer that ensures pygame-ce is available",
    "Interactive consent screen enforcing ethical use acknowledgment",
    "Full-featured listener CLI with file download, directory navigation, and heartbeat",
    "Cleanup tool to safely remove all simulated persistence artifacts",
    "Arcade gameplay: WASD movement, Space for plasma bolts, E to interact with terminals"
  ],
  "publicApiSurface": [
    "python game/main_game.py [--windowed] [--host <IP>] [--bg]",
    "python tools/listener.py",
    "python tools/cleanup_tool.py",
    "ReverseShell(host, port) — cyber_modules/network_shell.py",
    "ReverseShell.start() — begin background shell thread",
    "ReverseShell.stop() — gracefully terminate shell",
    "create_persistence(host) — cyber_modules/persistence.py",
    "remove_persistence() — cyber_modules/persistence.py",
    "ensure_dependencies(packages) — cyber_modules/dependency_checker.py",
    "Shell commands: ls, cd, cat, pwd, download <file>, quit"
  ]
